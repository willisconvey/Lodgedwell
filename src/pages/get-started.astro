---
import Base from '../layouts/Base.astro';
const title = "Get started \u2014 Onboard online | Lodgedwell";
const description = "Start your Victorian conveyancing online. Complete our short buying or selling form and a licensed conveyancer will be in touch within one business day.";
---
<Base title={title} description={description} active="" tally={true}>
<main>
<section class="page-hero center">
  <span class="blob blob-1"></span>
  <span class="blob blob-2"></span>
  <div class="container">
    <div class="section-head center reveal">
      <span class="eyebrow">Get started</span>
      <h1>Onboard online in minutes</h1>
      <p class="lead">Choose whether you're buying or selling and complete the guided form below. It's free to start, takes about 10 minutes, and a licensed Victorian conveyancer will be in touch within one business day.</p>
    </div>
    <div class="reveal" data-delay="1" style="margin-top:26px">
      <div class="tabs" role="tablist" aria-label="Choose a form">
        <button class="tab active" data-form-tab="buy" role="tab" aria-selected="true">I'm buying</button>
        <button class="tab" data-form-tab="sell" role="tab" aria-selected="false">I'm selling</button>
      </div>
    </div>
  </div>
</section>

<!-- FORMS -->
<section class="section" style="padding-top:8px">
  <div class="container" style="max-width:840px">
    <!-- BUY PANEL -->
    <div data-form-panel="buy" class="reveal">
      <div style="display:flex;align-items:center;gap:12px;margin-bottom:16px;flex-wrap:wrap">
        <span class="mock-badge" style="background:var(--green-100);color:var(--green-700)">Buying questionnaire</span>
        <span style="font-size:.9rem;color:var(--muted)">Takes ~10 minutes · Save and resume any time</span>
      </div>
      <div class="form-embed-card">
        <iframe
          data-tally-src="https://tally.so/embed/1A5xPl?alignLeft=1&amp;hideTitle=1&amp;transparentBackground=1&amp;dynamicHeight=1"
          loading="lazy"
          title="Lodgedwell buying questionnaire"
          height="760"></iframe>
      </div>
      <p style="text-align:center;margin-top:18px;font-size:.92rem;color:var(--muted)">
        Prefer to talk first? Call <a href="tel:1300000000" style="color:var(--green-700);font-weight:700">1300 000 000</a> or email <a href="mailto:hello@lodgedwell.com.au" style="color:var(--green-700);font-weight:700">hello@lodgedwell.com.au</a>.
      </p>
    </div>

    <!-- SELL PANEL -->
    <div data-form-panel="sell" hidden>
      <div style="display:flex;align-items:center;gap:12px;margin-bottom:16px;flex-wrap:wrap">
        <span class="mock-badge" style="background:var(--coral-100);color:var(--coral-600)">Property sales form</span>
        <span style="font-size:.9rem;color:var(--muted)">Takes ~10 minutes · Save and resume any time</span>
      </div>
      <div class="form-embed-card">
        <iframe
          data-tally-src="https://tally.so/embed/9q5aBQ?alignLeft=1&amp;hideTitle=1&amp;transparentBackground=1&amp;dynamicHeight=1"
          loading="lazy"
          title="Lodgedwell property sales form"
          height="760"></iframe>
      </div>
      <p style="text-align:center;margin-top:18px;font-size:.92rem;color:var(--muted)">
        Prefer to talk first? Call <a href="tel:1300000000" style="color:var(--green-700);font-weight:700">1300 000 000</a> or email <a href="mailto:hello@lodgedwell.com.au" style="color:var(--green-700);font-weight:700">hello@lodgedwell.com.au</a>.
      </p>
    </div>
  </div>
</section>

<!-- WHAT HAPPENS NEXT -->
<section class="section" style="background:var(--cream-200);border-block:1px solid var(--line);padding-top:clamp(48px,6vw,80px)">
  <div class="container">
    <div class="section-head center reveal" style="margin-bottom:44px">
      <span class="eyebrow">After you submit</span>
      <h2>What happens next</h2>
    </div>
    <div class="grid cols-3" style="max-width:940px;margin-inline:auto">
      <div class="card step-card reveal"><span class="step-num">1</span>
        <h3>We review your details</h3>
        <p>A licensed conveyancer checks everything you've submitted and confirms your fixed-fee quote.</p>
      </div>
      <div class="card step-card reveal" data-delay="1"><span class="step-num">2</span>
        <h3>We reach out</h3>
        <p>Within one business day you'll hear from a named conveyancer to introduce themselves and next steps.</p>
      </div>
      <div class="card step-card reveal" data-delay="2"><span class="step-num">3</span>
        <h3>You track it all</h3>
        <p>Once you're on board, follow every milestone through to settlement from your online dashboard.</p>
      </div>
    </div>
  </div>
</section>

<!-- TRUST STRIP -->
<section class="trust">
  <div class="container trust-inner">
    <span class="trust-label">You're in safe hands</span>
    <div class="trust-items">
      <span class="trust-item"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg> Encrypted &amp; secure</span>
      <span class="trust-item"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg> Free, no-obligation quote</span>
      <span class="trust-item"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2l3 6 6 .9-4.5 4.3 1 6.3L12 17l-5.5 2.5 1-6.3L3 8.9 9 8z"/></svg> Rated 4.9★ by Victorians</span>
    </div>
  </div>
</section>
</main>
</Base>
